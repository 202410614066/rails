<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Posts</h1>
  <%= link_to "Yeni Ekle", new_post_path, class: "btn btn-primary" %>
</div>

<div class="row">
  <% @posts.each do |post| %>
    <div class="col-md-8 mx-auto mt-4">
      <div class="card">
        <div class="card-header">
          <%= link_to post.title, post_path(post), class: "text-decoration-none" %>
        </div>

        <div class="card-body">
          <p><%= post.article %></p>
          <span class="badge bg-success"><%= post.status %></span>
        </div>

        <div class="card-footer">
          <%= link_to "Görüntüle", post_path(post), class: "btn btn-info btn-sm" %>
          <%= link_to "Güncelle", edit_post_path(post), class: "btn btn-outline-warning btn-sm" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
