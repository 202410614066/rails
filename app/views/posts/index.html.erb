<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><%= @user.fullname %> Yazıları</h1>

  <% if user_signed_in? && current_user == @user %>
    <%= link_to "Yeni Ekle", new_user_post_path(@user), class: "btn btn-primary" %>
  <% end %>
</div>

<div class="row">
  <% @posts.each do |post| %>
    <div class="col-md-8 mx-auto mt-4">
      <div class="card">
        <div class="card-header">
          <%= link_to post.title, user_post_path(post.user, post), class: "text-decoration-none" %>
        </div>

        <div class="card-body">
          <p><%= post.article %></p>
          <span class="badge bg-success"><%= post.status %></span>
        </div>

        <div class="card-footer">
          <%= link_to "Görüntüle", user_post_path(post.user, post), class: "btn btn-info btn-sm" %>

          <% if user_signed_in? && current_user == post.user %>
            <%= link_to "Güncelle", edit_user_post_path(post.user, post), class: "btn btn-outline-warning btn-sm" %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
