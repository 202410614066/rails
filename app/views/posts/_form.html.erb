<div class="row">
  <div class="col-md-8 mx-auto">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h4 class="mb-0"><%= form_title %></h4>
        <%= link_to "Geri", posts_path, class: "btn btn-secondary btn-sm" %>
      </div>

      <div class="card-body">
        <%= form_with model: post do |form| %>
          <div class="mb-3">
            <%= form.label :title, "Post Başlığı", class: "form-label" %>
            <%= form.text_field :title, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= form.label :article, "Post Metni", class: "form-label" %>
            <%= form.text_area :article, class: "form-control", rows: 5 %>
          </div>

          <div class="mb-3">
            <%= form.label :status, "Post Durumu", class: "form-label" %>
            <%= form.select :status, Post.statuses.keys, {}, class: "form-select" %>
          </div>

          <div class="text-center">
            <%= form.submit "Kaydet", class: "btn btn-success" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
