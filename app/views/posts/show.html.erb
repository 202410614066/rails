<div class="row">
  <div class="col-md-8 mx-auto">
    <div class="card">
      <% if @post.image.attached? %>
        <%= image_tag @post.image, class: "card-img-top", style: "max-height: 400px; object-fit: cover;" %>
      <% end %>

      <div class="card-header">
        <h4><%= @post.title %></h4>
      </div>

      <div class="card-body">
        <div class="text-center mb-3">
          <span class="badge bg-success"><%= @post.status %></span>

          <% @post.categories.each do |category| %>
            <span class="badge bg-primary"><%= category.name %></span>
          <% end %>
        </div>

        <hr>

        <p><%= @post.article %></p>
      </div>

      <div class="card-footer d-flex justify-content-between">
        <div>
          <%= link_to "Geri", posts_path, class: "btn btn-secondary btn-sm" %>
          <%= link_to "Güncelle", edit_post_path(@post), class: "btn btn-warning btn-sm" %>
        </div>

        <%= button_to "Sil", @post, method: :delete, data: { turbo_confirm: "Emin misin?" }, class: "btn btn-danger btn-sm" %>
      </div>
    </div>
  </div>
</div>
