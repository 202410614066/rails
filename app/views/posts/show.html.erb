<div class="row">
  <div class="col-md-8 mx-auto">
    <div class="card">
      <% if @post.image.attached? %>
        <%= image_tag @post.image, class: "card-img-top", style: "max-height: 400px; object-fit: cover;" %>
      <% end %>

      <div class="card-header">
        <h4><%= @post.title %></h4>
        <small class="text-muted">Yazar: <%= @post.user.fullname %></small>
      </div>

      <div class="card-body">
        <div class="text-center mb-3">
          <span class="badge bg-success"><%= @post.status %></span>

          <% @post.categories.each do |category| %>
            <span class="badge bg-primary"><%= category.name %></span>
          <% end %>
        </div>

        <hr>

        <p><%= @post.article %></p>
      </div>

      <div class="card-footer d-flex justify-content-between">
        <div>
          <%= link_to "Geri", user_posts_path(@user), class: "btn btn-secondary btn-sm" %>

          <% if user_signed_in? && current_user == @post.user %>
            <%= link_to "Güncelle", edit_user_post_path(@post.user, @post), class: "btn btn-warning btn-sm" %>
          <% end %>
        </div>

        <% if user_signed_in? && current_user == @post.user %>
          <%= button_to "Sil", user_post_path(@post.user, @post), method: :delete, data: { turbo_confirm: "Emin misin?" }, class: "btn btn-danger btn-sm" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
