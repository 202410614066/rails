<div class="row">
  <div class="col-md-8 mx-auto text-center">
    <div class="card shadow-sm">
      <div class="card-body">
        <% if @profile.image.present? %>
          <%= image_tag @profile.image, class: "rounded-circle mb-3", style: "width: 140px; height: 140px; object-fit: cover;" %>
        <% else %>
          <div class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center mb-3" style="width: 140px; height: 140px; font-size: 48px;">
            <%= @user.firstname.first %><%= @user.lastname.first %>
          </div>
        <% end %>

        <h2><%= @user.fullname %></h2>

        <div class="mt-3">
          <%= @profile.bio %>
        </div>

        <div class="mt-4">
          <% if @profile.github.present? %>
            <%= link_to "GitHub", @profile.github, class: "btn btn-dark btn-sm", target: "_blank" %>
          <% end %>

          <% if @profile.twitter.present? %>
            <%= link_to "X", @profile.twitter, class: "btn btn-secondary btn-sm", target: "_blank" %>
          <% end %>

          <% if @profile.linkedin.present? %>
            <%= link_to "LinkedIn", @profile.linkedin, class: "btn btn-primary btn-sm", target: "_blank" %>
          <% end %>
        </div>

        <% if current_user == @user %>
          <div class="mt-4">
            <%= link_to "Profili Düzenle", edit_user_profile_path(@user), class: "btn btn-warning" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
