<div class="row">
  <div class="col-md-8 mx-auto">
    <div class="card">
      <div class="card-header">
        <h3>Profil Bilgileri</h3>
      </div>

      <div class="card-body">
        <% if profile.errors.any? %>
          <div class="alert alert-danger">
            <ul class="mb-0">
              <% profile.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form_with model: [@user, profile], url: profile.persisted? ? user_profile_path(@user) : user_profile_path(@user) do |form| %>
          <div class="mb-3">
            <%= form.label :bio, "Hakkımda", class: "form-label" %>
            <%= form.rich_textarea :bio %>
          </div>

          <div class="mb-3">
            <%= form.label :image, "Profil Resmi URL", class: "form-label" %>
            <%= form.text_field :image, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= form.label :github, "Github", class: "form-label" %>
            <%= form.text_field :github, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= form.label :twitter, "Twitter / X", class: "form-label" %>
            <%= form.text_field :twitter, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= form.label :linkedin, "LinkedIn", class: "form-label" %>
            <%= form.text_field :linkedin, class: "form-control" %>
          </div>

          <%= form.submit "Kaydet", class: "btn btn-success" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
